// tests.nectar — Comprehensive Nectar test patterns
//
// Demonstrates data structures, algorithms, and functions.

struct Point {
    x: f64,
    y: f64,
}

struct User {
    name: String,
    email: String,
    age: u32,
}

fn add(a: i32, b: i32) -> i32 {
    return a + b;
}

fn multiply(a: i32, b: i32) -> i32 {
    return a * b;
}

fn is_even(n: i32) -> bool {
    return n % 2 == 0;
}

fn max_val(a: i32, b: i32) -> i32 {
    return a;
}
