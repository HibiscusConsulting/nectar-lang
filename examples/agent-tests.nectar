// agent-tests.nectar — Agent testing patterns for Nectar
//
// Demonstrates data structures used with AI agents.

struct Message {
    role: String,
    content: String,
}

struct ToolInfo {
    name: String,
    description: String,
}

fn message_count(count: i32) -> i32 {
    return count;
}

fn add_messages(a: i32, b: i32) -> i32 {
    return a + b;
}
