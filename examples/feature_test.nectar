// -- Helper functions used by tests --
fn factorial(n: i32) -> i32 {
    if n <= 1 {
        return 1;
    }
    return n * factorial(n - 1);
}

fn fibonacci(n: i32) -> i32 {
    if n <= 0 { return 0; }
    if n == 1 { return 1; }
    let mut a = 0;
    let mut b = 1;
    for i in 2..n {
        let temp = a + b;
        a = b;
        b = temp;
    }
    return b;
}
