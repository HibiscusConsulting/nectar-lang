    // ======================================================
    // Navigation
    // ======================================================

    fn show_menu(&mut self) {
        self.active_tab = 0;
    }

    fn show_cart(&mut self) {
        self.active_tab = 1;
        self.recalculate_totals();
    }

    fn show_orders(&mut self) {
        self.active_tab = 2;
    }

    fn show_profile(&mut self) {
        self.active_tab = 3;
    }

    fn show_stores(&mut self) {
        self.active_tab = 4;
        self.calculate_distances();
    }

    // ======================================================
    // Category filtering
    // ======================================================

    fn filter_all(&mut self) {
        self.category_idx = 0;
    }

    fn filter_espresso(&mut self) {
        self.category_idx = 1;
    }

    fn filter_latte(&mut self) {
        self.category_idx = 2;
    }

    fn filter_cold(&mut self) {
        self.category_idx = 3;
    }

    fn filter_tea(&mut self) {
        self.category_idx = 4;
    }

    fn filter_pastry(&mut self) {
        self.category_idx = 5;
    }

    // ======================================================
    // Sort controls
    // ======================================================

    fn sort_default(&mut self) {
        self.sort_mode = 0;
    }

    fn sort_price_asc(&mut self) {
