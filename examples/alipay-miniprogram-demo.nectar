    let mut cart_q12: i32 = 0;
    let mut cart_q13: i32 = 0;
    let mut cart_q14: i32 = 0;
    let mut cart_q15: i32 = 0;
    let mut cart_q16: i32 = 0;
    let mut cart_q17: i32 = 0;
    let mut cart_q18: i32 = 0;
    let mut cart_q19: i32 = 0;
    let mut cart_q20: i32 = 0;
