// alipay-miniprogram-demo.nectar — Alipay Mini-Program Coffee Shop Demo
//
// Demonstrates: Nectar's miniprogram keyword as a drop-in replacement for
// Alipay's mini-program runtime. Instead of a JavaScript sandbox, mini-programs
// compile to WASM with hardware-level memory isolation.
//
// The mp:: API surface mirrors Alipay's my.* APIs:
//   mp::getStorageSync / mp::setStorageSync  — persistent key-value store
//   mp::showLoading / mp::hideLoading        — loading overlay
//   mp::showToast                            — toast notification
//   mp::getAuthCode                          — Alipay OAuth flow
//   mp::getUserInfo                          — user profile from Alipay
//   mp::tradePay                             — QR / barcode payment
//   mp::getNetworkType                       — connectivity check
//   mp::getLocation                          — GPS coordinates
//   mp::navigateTo / mp::navigateBack        — page navigation stack
//   mp::request                              — HTTP fetch
//   mp::setNavigationBar                     — top bar config
//
// Architecture:
//   Alipay App Host  →  WASM Sandbox (Nectar Binary)  →  mp:: syscall layer
//   vs.
//   Alipay App Host  →  JS Sandbox (V8 Isolate)  →  my.* bridge  →  native
//
// The WASM binary is portable: swap payment_provider from "alipay" to "stripe"
// or "moov" with one line. The business logic is identical.
//
// Compile: nectar build examples/alipay-miniprogram-demo.nectar --emit-wasm

miniprogram AlipayDemo {
    payment_provider: "alipay"
    auth_provider: "alipay"
    map_provider: "amap"
    offline: true
    cache_strategy: "cache-first"

    fn onLaunch(options: String) {
        let token: String = mp::getStorageSync("auth_token");
        let cached_cart: String = mp::getStorageSync("cart_data");
        mp::showLoading("Loading...");
        mp::setNavigationBar("Nectar Coffee", "#1a472a", "#fafafa");
    }

    fn onShow() {
        let net: String = mp::getNetworkType();
        mp::hideLoading();
    }

    fn onHide() {
        mp::setStorageSync("last_active", "timestamp");
        mp::setStorageSync("cart_data", "saved");
    }
}

// --- Data structures ---

struct MenuItem {
    id: i32,
    name: String,
    price_cents: i32,
    category: String,
    description: String,
}

struct CartItem {
    item_name: String,
    quantity: i32,
    unit_price_cents: i32,
}

struct OrderRecord {
    order_id: i32,
    total_cents: i32,
    item_count: i32,
    status: String,
}

struct StoreLocation {
    name: String,
    lat_x1000: i32,
    lng_x1000: i32,
    address: String,
    hours: String,
}

// --- Main Application Component ---

component CoffeeShopApp() {
