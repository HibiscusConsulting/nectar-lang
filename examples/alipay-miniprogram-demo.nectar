    let mut price0: i32 = 275;
    let mut price1: i32 = 325;
    let mut price2: i32 = 395;
    let mut price3: i32 = 450;
    let mut price4: i32 = 475;
    let mut price5: i32 = 525;
    let mut price6: i32 = 550;
    let mut price7: i32 = 495;
    let mut price8: i32 = 575;
    let mut price9: i32 = 425;
    let mut price10: i32 = 475;
    let mut price11: i32 = 525;
    let mut price12: i32 = 375;
    let mut price13: i32 = 425;
    let mut price14: i32 = 350;
    let mut price15: i32 = 395;
    let mut price16: i32 = 300;
    let mut price17: i32 = 325;
    let mut price18: i32 = 375;
    let mut price19: i32 = 295;
    let mut price20: i32 = 425;
    let mut price21: i32 = 350;

    // === Payment state ===
    let mut payment_status: i32 = 0;
    let mut payment_countdown: i32 = 30;
    let mut order_id_seed: i32 = 100000;
    let mut current_order_id: i32 = 0;
