// AI Chat Interface — demonstrates Nectar's first-class AI interaction primitives
//
// The `agent` keyword defines a component that wraps LLM interaction.
// Tools are functions the AI can call, and the render block provides
// the reactive UI — each streamed token updates the DOM automatically.

component ChatInterface() {
    let mut input: String = "";
    let mut streaming: bool = false;
    let mut message_count: i32 = 0;

    fn send(&mut self) {
        self.message_count = self.message_count + 1;
        self.input = "";
        self.streaming = true;
    }

    fn on_stream_done(&mut self) {
        self.streaming = false;
    }

    fn clear_history(&mut self) {
        self.message_count = 0;
    }

    render {
        <div class="chat">
            <div class="messages">
                <p>{format("Messages: {}", self.message_count)}</p>
                {if self.streaming {
                    <div class="typing">
                        <span class="dot">"."</span>
                        <span class="dot">"."</span>
                        <span class="dot">"."</span>
                    </div>
                }}
            </div>
            <div class="input-area">
                <input
                    value={format("{}", self.input)}
                    placeholder="Ask me anything..."
                />
                <button on:click={self.send}>"Send"</button>
                <button on:click={self.clear_history}>"Clear"</button>
            </div>
        </div>
    }
}
