// =============================================================================
// component-tests.nectar — Component testing patterns for Nectar
//
// These tests use Nectar's built-in test renderer to mount components into a
// virtual DOM, simulate user interactions, and verify the resulting output.
//
// Run with:   nectar test examples/component-tests.nectar
// Filter:     nectar test examples/component-tests.nectar --filter "counter"
// =============================================================================

// ---------------------------------------------------------------------------
// Components under test
// ---------------------------------------------------------------------------

component Greeting(name: String = "World") {
    render {
        <div class="greeting">
            <h1>{format("Hello, {}!", self.name)}</h1>
        </div>
    }
}

component Counter(initial: i32 = 0) {
    let mut count: i32 = initial;

    fn increment(&mut self) {
        self.count = self.count + 1;
    }

    fn decrement(&mut self) {
        self.count = self.count - 1;
    }

    fn reset(&mut self) {
        self.count = 0;
    }

    render {
        <div class="counter">
            <span role="counter">{self.count}</span>
            <button class="inc" on:click={self.increment}>"+1"</button>
            <button class="dec" on:click={self.decrement}>"-1"</button>
            <button class="reset" on:click={self.reset}>"Reset"</button>
        </div>
    }
}

struct TodoItem {
    id: u32,
    text: String,
    done: bool,
}

component TodoList() {
    let mut todos: [TodoItem] = [];
    let mut next_id: u32 = 0;
    let mut input_text: String = "";

    fn add_todo(&mut self) {
        if self.input_text.len() > 0 {
            self.todos.push(TodoItem {
                id: self.next_id,
                text: self.input_text,
                done: false,
            });
            self.next_id = self.next_id + 1;
            self.input_text = "";
        }
    }

    fn toggle(&mut self, id: u32) {
        for todo in &mut self.todos {
            if todo.id == id {
                todo.done = !todo.done;
            }
        }
    }

    fn active_count(&self) -> u32 {
        let mut count: u32 = 0;
        for todo in &self.todos {
            if !todo.done {
                count = count + 1;
            }
        }
        count
    }

    render {
        <div class="todo-list">
            <div class="input-row">
                <input bind:value={input_text} placeholder="What needs to be done?" />
                <button class="add-btn" on:click={self.add_todo}>"Add"</button>
            </div>
            <ul>
                {for todo in &self.todos {
                    <li class={if todo.done { "done" } else { "active" }}>
                        <span class="todo-text">{todo.text}</span>
                        <button on:click={self.toggle(todo.id)}>"Toggle"</button>
                    </li>
                }}
            </ul>
            <p class="remaining">{format("{} items left", self.active_count())}</p>
        </div>
    }
}

enum Theme {
    Light,
    Dark,
}

component ThemeToggle() {
    let mut theme: Theme = Theme::Light;

    fn toggle_theme(&mut self) {
        self.theme = match self.theme {
            Theme::Light => Theme::Dark,
            Theme::Dark => Theme::Light,
        };
    }

    fn theme_label(&self) -> String {
        match self.theme {
            Theme::Light => "Light Mode",
            Theme::Dark => "Dark Mode",
        }
    }

    render {
        <div class={match self.theme { Theme::Light => "light", Theme::Dark => "dark" }}>
            <span role="status">{self.theme_label()}</span>
            <button on:click={self.toggle_theme}>"Toggle Theme"</button>
        </div>
    }
}

store AppCounterStore {
    signal count: i32 = 0;

    action increment(&mut self) {
        self.count = self.count + 1;
    }

    action decrement(&mut self) {
        self.count = self.count - 1;
    }

    computed display_text(&self) -> String {
        format("Store count: {}", self.count)
    }
}

component StoreCounter() {
    render {
        <div class="store-counter">
            <span role="display">{AppCounterStore::display_text()}</span>
            <button class="inc" on:click={AppCounterStore::increment}>"+1"</button>
            <button class="dec" on:click={AppCounterStore::decrement}>"-1"</button>
        </div>
    }
}

component ConditionalMessage(show: bool = false) {
    render {
        <div>
            {if self.show {
                <p class="message">"This message is visible"</p>
            }}
            {if !self.show {
                <p class="placeholder">"Nothing to see here"</p>
            }}
        </div>
    }
}

component NumberList(items: [i32] = []) {
    fn total(&self) -> i32 {
        let mut sum: i32 = 0;
        for item in &self.items {
            sum = sum + item;
        }
        sum
    }

    render {
        <div class="number-list">
            <ul>
                {for item in &self.items {
                    <li class="list-item">{item}</li>
                }}
            </ul>
            <p class="total">{format("Total: {}", self.total())}</p>
        </div>
    }
}

// ===========================================================================
// 1. Mounting and Initial Render
// ===========================================================================

test "greeting renders with default prop" {
    let el = render(<Greeting />);
    let heading = el.findByText("Hello, World!");
    assert(heading.exists());
}

test "greeting renders with custom prop" {
    let el = render(<Greeting name="Nectar" />);
    let heading = el.findByText("Hello, Nectar!");
    assert(heading.exists());
}

test "counter renders initial value" {
    let el = render(<Counter />);
    let display = el.findByRole("counter");
    assert_eq(display.getText(), "0");
}

test "counter renders custom initial value" {
    let el = render(<Counter initial={10} />);
    let display = el.findByRole("counter");
    assert_eq(display.getText(), "10");
}

// ===========================================================================
// 2. Simulating Clicks and Verifying State Changes
// ===========================================================================

test "counter increments on click" {
    let el = render(<Counter />);
    let inc_btn = el.findByText("+1");
    let display = el.findByRole("counter");

    inc_btn.click();
    assert_eq(display.getText(), "1");

    inc_btn.click();
    inc_btn.click();
    assert_eq(display.getText(), "3");
}

test "counter decrements on click" {
    let el = render(<Counter initial={5} />);
    let dec_btn = el.findByText("-1");
    let display = el.findByRole("counter");

    dec_btn.click();
    assert_eq(display.getText(), "4");
}

test "counter resets to zero" {
    let el = render(<Counter initial={10} />);
    let reset_btn = el.findByText("Reset");
    let display = el.findByRole("counter");

    reset_btn.click();
    assert_eq(display.getText(), "0");
}

test "counter handles multiple operations" {
    let el = render(<Counter />);
    let inc_btn = el.findByText("+1");
    let dec_btn = el.findByText("-1");
    let display = el.findByRole("counter");

    inc_btn.click();  // 1
    inc_btn.click();  // 2
    inc_btn.click();  // 3
    dec_btn.click();  // 2

    assert_eq(display.getText(), "2");
}

// ===========================================================================
// 3. Testing Props with Default Values
// ===========================================================================

test "default props are applied" {
    let el = render(<Greeting />);
    // "World" is the default for the name prop
    let heading = el.findByText("Hello, World!");
    assert(heading.exists());
}

test "explicit props override defaults" {
    let el = render(<Counter initial={100} />);
    let display = el.findByRole("counter");
    assert_eq(display.getText(), "100");
}

test "conditional message with default false" {
    let el = render(<ConditionalMessage />);
    let placeholder = el.findByText("Nothing to see here");
    assert(placeholder.exists());
}

// ===========================================================================
// 4. Testing Signal Updates and DOM Reactivity
// ===========================================================================

test "theme toggle updates displayed text" {
    let el = render(<ThemeToggle />);
    let status = el.findByRole("status");
    assert_eq(status.getText(), "Light Mode");

    let toggle_btn = el.findByText("Toggle Theme");
    toggle_btn.click();
    assert_eq(status.getText(), "Dark Mode");

    toggle_btn.click();
    assert_eq(status.getText(), "Light Mode");
}

test "theme toggle updates container class" {
    let el = render(<ThemeToggle />);
    let container = el.children()[0];
    assert_eq(container.getAttribute("class"), "light");

    let toggle_btn = el.findByText("Toggle Theme");
    toggle_btn.click();
    assert_eq(container.getAttribute("class"), "dark");
}

// ===========================================================================
// 5. Testing Conditional Rendering
// ===========================================================================

test "conditional rendering shows message when true" {
    let el = render(<ConditionalMessage show={true} />);
    let message = el.findByText("This message is visible");
    assert(message.exists());
}

test "conditional rendering shows placeholder when false" {
    let el = render(<ConditionalMessage show={false} />);
    let placeholder = el.findByText("Nothing to see here");
    assert(placeholder.exists());
}

// ===========================================================================
// 6. Testing List Rendering (For Loops)
// ===========================================================================

test "number list renders all items" {
    let el = render(<NumberList items={[10, 20, 30]} />);
    let children = el.findByAttribute("class", "number-list").children();
    // ul with 3 li elements, plus total paragraph
    let list_items = el.findByText("10");
    assert(list_items.exists());
    let item2 = el.findByText("20");
    assert(item2.exists());
    let item3 = el.findByText("30");
    assert(item3.exists());
}

test "number list renders total" {
    let el = render(<NumberList items={[10, 20, 30]} />);
    let total = el.findByText("Total: 60");
    assert(total.exists());
}

test "empty list renders zero total" {
    let el = render(<NumberList items={[]} />);
    let total = el.findByText("Total: 0");
    assert(total.exists());
}

test "todo list starts empty" {
    let el = render(<TodoList />);
    let remaining = el.findByText("0 items left");
    assert(remaining.exists());
}

// ===========================================================================
// 7. Testing Event Handlers
// ===========================================================================

test "todo list add button creates item" {
    let el = render(<TodoList />);
    let input = el.findByAttribute("placeholder", "What needs to be done?");
    let add_btn = el.findByText("Add");

    input.type("Buy groceries");
    add_btn.click();

    let todo = el.findByText("Buy groceries");
    assert(todo.exists());
    let remaining = el.findByText("1 items left");
    assert(remaining.exists());
}

test "todo list toggle marks item done" {
    let el = render(<TodoList />);
    let input = el.findByAttribute("placeholder", "What needs to be done?");
    let add_btn = el.findByText("Add");

    input.type("Buy groceries");
    add_btn.click();

    let toggle_btn = el.findByText("Toggle");
    toggle_btn.click();

    let remaining = el.findByText("0 items left");
    assert(remaining.exists());
}

test "todo list multiple items and interactions" {
    let el = render(<TodoList />);
    let input = el.findByAttribute("placeholder", "What needs to be done?");
    let add_btn = el.findByText("Add");

    input.type("Task A");
    add_btn.click();
    input.type("Task B");
    add_btn.click();
    input.type("Task C");
    add_btn.click();

    let remaining = el.findByText("3 items left");
    assert(remaining.exists());

    // Verify all items rendered
    assert(el.findByText("Task A").exists());
    assert(el.findByText("Task B").exists());
    assert(el.findByText("Task C").exists());
}

// ===========================================================================
// 8. Testing Store Integration from Components
// ===========================================================================

test "store counter displays initial value" {
    let el = render(<StoreCounter />);
    let display = el.findByRole("display");
    assert_eq(display.getText(), "Store count: 0");
}

test "store counter increment updates display" {
    let el = render(<StoreCounter />);
    let inc_btn = el.findByText("+1");
    let display = el.findByRole("display");

    inc_btn.click();
    assert_eq(display.getText(), "Store count: 1");
}

test "store counter decrement updates display" {
    let el = render(<StoreCounter />);
    let inc_btn = el.findByText("+1");
    let dec_btn = el.findByText("-1");
    let display = el.findByRole("display");

    inc_btn.click();
    inc_btn.click();
    inc_btn.click();
    dec_btn.click();
    assert_eq(display.getText(), "Store count: 2");
}

test "store state is shared across component instances" {
    // Both components read from the same AppCounterStore
    let el1 = render(<StoreCounter />);
    let el2 = render(<StoreCounter />);

    let inc_btn = el1.findByText("+1");
    inc_btn.click();

    // Both should reflect the updated store value
    let display1 = el1.findByRole("display");
    let display2 = el2.findByRole("display");
    assert_eq(display1.getText(), display2.getText());
}
