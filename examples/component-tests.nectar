// component-tests.nectar — Component testing patterns for Nectar

component Counter() {
    let mut count: i32 = 0;

    fn increment(&mut self) {
        self.count = self.count + 1;
    }

    fn decrement(&mut self) {
        self.count = self.count - 1;
    }

    fn reset(&mut self) {
        self.count = 0;
    }

    render {
        <div class="counter">
            <span role="counter">{self.count}</span>
            <button class="inc" on:click={self.increment}>"+1"</button>
            <button class="dec" on:click={self.decrement}>"-1"</button>
            <button class="reset" on:click={self.reset}>"Reset"</button>
        </div>
    }
}

component ConditionalMessage() {
    let mut visible: bool = false;

    fn toggle(&mut self) {
        self.visible = !self.visible;
    }

    render {
        <div>
            {if self.visible {
                <p class="message">"This message is visible"</p>
            }}
            {if !self.visible {
                <p class="placeholder">"Nothing to see here"</p>
            }}
            <button on:click={self.toggle}>"Toggle"</button>
        </div>
    }
}
