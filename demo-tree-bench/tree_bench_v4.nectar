    render {
        <div style="direction: vertical; width: fill; height: fill; background-color: #f6f8fa; padding: 14; gap: 8">
            <div style="direction: horizontal; gap: 12; align: center; height: 26px">
                <div style="font-size: 16px; font-weight: 700; color: #9a6700">"PLM/ALM Tree Navigator"</div>
                <div style="font-size: 11px; color: #6e7781">"live against a mock Windchill-style BOM REST API (~120ms/call) · lazy-loads each level on demand · Nectar/Honeycomb canvas mode"</div>
            </div>
            <div style="font-size: 12px; color: #57606a; height: 16px">{self.status}</div>
            <div style="direction: horizontal; gap: 4; height: 28px">
                <div style="height: 26px; padding: 0 10; background-color: #f6f8fa; border: 1px solid #d0d7de; border-radius: 4; color: #24292f; font-size: 11px; align: center; justify: center; cursor: pointer" on:click={self.setup}>"Connect"</div>
                <div style="height: 26px; padding: 0 10; background-color: #f6f8fa; border: 1px solid #d0d7de; border-radius: 4; color: #24292f; font-size: 11px; align: center; justify: center; cursor: pointer" on:click={self.import_all}>"Import full BOM (~100K)"</div>
                <div style="height: 26px; padding: 0 10; background-color: #f6f8fa; border: 1px solid #d0d7de; border-radius: 4; color: #24292f; font-size: 11px; align: center; justify: center; cursor: pointer" on:click={self.expand_loaded}>"Expand loaded"</div>
                <div style="height: 26px; padding: 0 10; background-color: #f6f8fa; border: 1px solid #d0d7de; border-radius: 4; color: #24292f; font-size: 11px; align: center; justify: center; cursor: pointer" on:click={self.collapse_all}>"Collapse all"</div>
                <div style="height: 26px; padding: 0 10; background-color: #f6f8fa; border: 1px solid #d0d7de; border-radius: 4; color: #24292f; font-size: 11px; align: center; justify: center; cursor: pointer" on:click={self.scroll_to_top}>"Top"</div>
            </div>
            <div style="direction: horizontal; gap: 4; height: 26px; align: center">
                <div style="font-size: 11px; font-weight: 700; color: #6e7781; padding: 0 4">"SEARCH"</div>
                <input style="width: 220px; height: 24px; padding: 0 8; background-color: #ffffff; border: 1px solid #d0d7de; border-radius: 4; font-size: 12px; color: #1f2328; cursor: text" bind:value={query} on:input={self.on_search} />
                <div style="font-size: 11px; font-weight: 700; color: #6e7781; padding: 0 4">"FILTER"</div>
                <div style="height: 24px; padding: 0 10; background-color: #eef1f4; border: 1px solid #d0d7de; border-radius: 12; color: #24292f; font-size: 11px; align: center; justify: center; cursor: pointer" on:click={self.filter_all}>"All (tree)"</div>
                <div style="height: 24px; padding: 0 10; background-color: #eef1f4; border: 1px solid #d0d7de; border-radius: 12; color: #24292f; font-size: 11px; align: center; justify: center; cursor: pointer" on:click={self.filter_released}>"Released"</div>
                <div style="height: 24px; padding: 0 10; background-color: #eef1f4; border: 1px solid #d0d7de; border-radius: 12; color: #24292f; font-size: 11px; align: center; justify: center; cursor: pointer" on:click={self.filter_inwork}>"In Work"</div>
                <div style="height: 24px; padding: 0 10; background-color: #eef1f4; border: 1px solid #d0d7de; border-radius: 12; color: #24292f; font-size: 11px; align: center; justify: center; cursor: pointer" on:click={self.filter_review}>"Under Review"</div>
                <div style="height: 24px; padding: 0 10; background-color: #eef1f4; border: 1px solid #d0d7de; border-radius: 12; color: #24292f; font-size: 11px; align: center; justify: center; cursor: pointer" on:click={self.filter_obsolete}>"Obsolete"</div>
                <div style="height: 24px; padding: 0 10; background-color: #eef1f4; border: 1px solid #d0d7de; border-radius: 12; color: #24292f; font-size: 11px; align: center; justify: center; cursor: pointer" on:click={self.filter_fasteners}>"Fasteners"</div>
                <div style="height: 24px; padding: 0 10; background-color: #eef1f4; border: 1px solid #d0d7de; border-radius: 12; color: #24292f; font-size: 11px; align: center; justify: center; cursor: pointer" on:click={self.filter_assemblies}>"Assemblies"</div>
                <div style="font-size: 11px; color: #6e7781; padding: 0 6">{format("→ {}", self.filter_label)}</div>
            </div>
            <div style="direction: horizontal; gap: 8; height: 22px; align: center">
                <div style="direction: horizontal; width: 104px; height: 18px; background-color: #eef1f4; border-radius: 3; cursor: pointer; align: center; padding-left: 6" on:click={self.breadcrumb_jump_0}>
                    <div style="width: 12px; font-size: 11px; color: #9a6700">{if self.window_depths.len() > 0 { {if self.window_depths[0] == 0 { "▸" } else { " " }} } else { " " }}</div>
                    <div style="font-size: 11px; color: #57606a">"Top Assembly"</div>
                </div>
                <div style="direction: horizontal; width: 116px; height: 18px; background-color: #eef1f4; border-radius: 3; cursor: pointer; align: center; padding-left: 6" on:click={self.breadcrumb_jump_1}>
                    <div style="width: 12px; font-size: 11px; color: #9a6700">{if self.window_depths.len() > 0 { {if self.window_depths[0] == 1 { "▸" } else { " " }} } else { " " }}</div>
                    <div style="font-size: 11px; color: #57606a">"Major Assembly"</div>
                </div>
                <div style="direction: horizontal; width: 108px; height: 18px; background-color: #eef1f4; border-radius: 3; cursor: pointer; align: center; padding-left: 6" on:click={self.breadcrumb_jump_2}>
                    <div style="width: 12px; font-size: 11px; color: #9a6700">{if self.window_depths.len() > 0 { {if self.window_depths[0] == 2 { "▸" } else { " " }} } else { " " }}</div>
                    <div style="font-size: 11px; color: #57606a">"Sub-Assembly"</div>
                </div>
                <div style="direction: horizontal; width: 98px; height: 18px; background-color: #eef1f4; border-radius: 3; cursor: pointer; align: center; padding-left: 6" on:click={self.breadcrumb_jump_3}>
                    <div style="width: 12px; font-size: 11px; color: #9a6700">{if self.window_depths.len() > 0 { {if self.window_depths[0] == 3 { "▸" } else { " " }} } else { " " }}</div>
                    <div style="font-size: 11px; color: #57606a">"Component"</div>
