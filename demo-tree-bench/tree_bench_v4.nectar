                {if self.uses_ids.len() > 2 {
                    <div style="direction: horizontal; height: 24px; background-color: #ffffff; border-bottom: 1px solid #e6e8eb; align: center; padding-left: 10">
                        <div style="width: 120px; font-size: 12px; color: #1f2328">{format("PN-{}", self.uses_ids[2])}</div>
                        <div style="width: 220px; font-size: 12px; color: #57606a">{format("{}", self.names[self.uses_ids[2]])}</div>
                        <div style="width: 110px; font-size: 12px; color: #57606a">"A.1 (Design)"</div>
                        <div style="width: 130px; direction: horizontal; gap: 5; align: center"><div style="width: 9px; height: 24px; align: center; justify: center">{if (self.eff_state[self.uses_ids[2]]) == 0 { <div style="width: 7px; height: 7px; border-radius: 4; background-color: #1a7f37"></div> } else { {if (self.eff_state[self.uses_ids[2]]) == 1 { <div style="width: 7px; height: 7px; border-radius: 4; background-color: #0969da"></div> } else { {if (self.eff_state[self.uses_ids[2]]) == 2 { <div style="width: 7px; height: 7px; border-radius: 4; background-color: #9a6700"></div> } else { <div style="width: 7px; height: 7px; border-radius: 4; background-color: #6e7781"></div> }} }} }}</div><div style="font-size: 12px; color: #57606a">{if (self.eff_state[self.uses_ids[2]]) == 0 { "Released" } else { {if (self.eff_state[self.uses_ids[2]]) == 1 { "In Work" } else { {if (self.eff_state[self.uses_ids[2]]) == 2 { "Under Review" } else { "Obsolete" }} }} }}</div></div>
                        <div style="width: 80px; font-size: 12px; color: #57606a">{format("{}", self.qty[self.uses_ids[2]])}</div>
                        <div style="width: 60px; font-size: 12px; color: #57606a">"each"</div>
                    </div>
                }}
                {if self.uses_ids.len() > 3 {
                    <div style="direction: horizontal; height: 24px; background-color: #f9fafb; border-bottom: 1px solid #e6e8eb; align: center; padding-left: 10">
                        <div style="width: 120px; font-size: 12px; color: #1f2328">{format("PN-{}", self.uses_ids[3])}</div>
                        <div style="width: 220px; font-size: 12px; color: #57606a">{format("{}", self.names[self.uses_ids[3]])}</div>
                        <div style="width: 110px; font-size: 12px; color: #57606a">"A.1 (Design)"</div>
                        <div style="width: 130px; direction: horizontal; gap: 5; align: center"><div style="width: 9px; height: 24px; align: center; justify: center">{if (self.eff_state[self.uses_ids[3]]) == 0 { <div style="width: 7px; height: 7px; border-radius: 4; background-color: #1a7f37"></div> } else { {if (self.eff_state[self.uses_ids[3]]) == 1 { <div style="width: 7px; height: 7px; border-radius: 4; background-color: #0969da"></div> } else { {if (self.eff_state[self.uses_ids[3]]) == 2 { <div style="width: 7px; height: 7px; border-radius: 4; background-color: #9a6700"></div> } else { <div style="width: 7px; height: 7px; border-radius: 4; background-color: #6e7781"></div> }} }} }}</div><div style="font-size: 12px; color: #57606a">{if (self.eff_state[self.uses_ids[3]]) == 0 { "Released" } else { {if (self.eff_state[self.uses_ids[3]]) == 1 { "In Work" } else { {if (self.eff_state[self.uses_ids[3]]) == 2 { "Under Review" } else { "Obsolete" }} }} }}</div></div>
                        <div style="width: 80px; font-size: 12px; color: #57606a">{format("{}", self.qty[self.uses_ids[3]])}</div>
                        <div style="width: 60px; font-size: 12px; color: #57606a">"each"</div>
                    </div>
                }}
                {if self.uses_ids.len() > 4 {
                    <div style="direction: horizontal; height: 24px; background-color: #ffffff; border-bottom: 1px solid #e6e8eb; align: center; padding-left: 10">
                        <div style="width: 120px; font-size: 12px; color: #1f2328">{format("PN-{}", self.uses_ids[4])}</div>
                        <div style="width: 220px; font-size: 12px; color: #57606a">{format("{}", self.names[self.uses_ids[4]])}</div>
                        <div style="width: 110px; font-size: 12px; color: #57606a">"A.1 (Design)"</div>
                        <div style="width: 130px; direction: horizontal; gap: 5; align: center"><div style="width: 9px; height: 24px; align: center; justify: center">{if (self.eff_state[self.uses_ids[4]]) == 0 { <div style="width: 7px; height: 7px; border-radius: 4; background-color: #1a7f37"></div> } else { {if (self.eff_state[self.uses_ids[4]]) == 1 { <div style="width: 7px; height: 7px; border-radius: 4; background-color: #0969da"></div> } else { {if (self.eff_state[self.uses_ids[4]]) == 2 { <div style="width: 7px; height: 7px; border-radius: 4; background-color: #9a6700"></div> } else { <div style="width: 7px; height: 7px; border-radius: 4; background-color: #6e7781"></div> }} }} }}</div><div style="font-size: 12px; color: #57606a">{if (self.eff_state[self.uses_ids[4]]) == 0 { "Released" } else { {if (self.eff_state[self.uses_ids[4]]) == 1 { "In Work" } else { {if (self.eff_state[self.uses_ids[4]]) == 2 { "Under Review" } else { "Obsolete" }} }} }}</div></div>
                        <div style="width: 80px; font-size: 12px; color: #57606a">{format("{}", self.qty[self.uses_ids[4]])}</div>
                        <div style="width: 60px; font-size: 12px; color: #57606a">"each"</div>
                    </div>
                }}
                {if self.uses_ids.len() > 5 {
                    <div style="direction: horizontal; height: 24px; background-color: #f9fafb; border-bottom: 1px solid #e6e8eb; align: center; padding-left: 10">
                        <div style="width: 120px; font-size: 12px; color: #1f2328">{format("PN-{}", self.uses_ids[5])}</div>
                        <div style="width: 220px; font-size: 12px; color: #57606a">{format("{}", self.names[self.uses_ids[5]])}</div>
                        <div style="width: 110px; font-size: 12px; color: #57606a">"A.1 (Design)"</div>
                        <div style="width: 130px; direction: horizontal; gap: 5; align: center"><div style="width: 9px; height: 24px; align: center; justify: center">{if (self.eff_state[self.uses_ids[5]]) == 0 { <div style="width: 7px; height: 7px; border-radius: 4; background-color: #1a7f37"></div> } else { {if (self.eff_state[self.uses_ids[5]]) == 1 { <div style="width: 7px; height: 7px; border-radius: 4; background-color: #0969da"></div> } else { {if (self.eff_state[self.uses_ids[5]]) == 2 { <div style="width: 7px; height: 7px; border-radius: 4; background-color: #9a6700"></div> } else { <div style="width: 7px; height: 7px; border-radius: 4; background-color: #6e7781"></div> }} }} }}</div><div style="font-size: 12px; color: #57606a">{if (self.eff_state[self.uses_ids[5]]) == 0 { "Released" } else { {if (self.eff_state[self.uses_ids[5]]) == 1 { "In Work" } else { {if (self.eff_state[self.uses_ids[5]]) == 2 { "Under Review" } else { "Obsolete" }} }} }}</div></div>
                        <div style="width: 80px; font-size: 12px; color: #57606a">{format("{}", self.qty[self.uses_ids[5]])}</div>
                        <div style="width: 60px; font-size: 12px; color: #57606a">"each"</div>
                    </div>
                }}
            </div>
            <div style="direction: vertical; width: fill; height: 170px; background-color: #ffffff; border: 1px solid #d0d7de; border-radius: 4">
                <div style="height: 26px; background-color: #f6f8fa; border-bottom: 1px solid #d0d7de; padding: 0 10; align: center; direction: horizontal; gap: 8"><div style="font-size: 11px; font-weight: 700; color: #57606a">"RAW RESPONSE"</div><div style="font-size: 11px; color: #6e7781">{format("{} · {} nodes in last payload", self.last_url, self.fetched.len())}</div></div>
                <div style="direction: vertical; padding: 8 10; gap: 1">
                    <div style="font-size: 11px; color: #6e7781">"["</div>
                    {if self.fetched.len() > 0 {
                        <div style="font-size: 11px; color: #24292f">{format("  {{\"id\": {}, \"name\": \"{}\", \"leaf\": {}, \"state\": {}, \"qty\": {}}},", self.fetched[0].id, self.fetched[0].name, self.fetched[0].leaf, self.fetched[0].state, self.fetched[0].qty)}</div>
                    }}
                    {if self.fetched.len() > 1 {
                        <div style="font-size: 11px; color: #24292f">{format("  {{\"id\": {}, \"name\": \"{}\", \"leaf\": {}, \"state\": {}, \"qty\": {}}},", self.fetched[1].id, self.fetched[1].name, self.fetched[1].leaf, self.fetched[1].state, self.fetched[1].qty)}</div>
                    }}
                    {if self.fetched.len() > 2 {
                        <div style="font-size: 11px; color: #24292f">{format("  {{\"id\": {}, \"name\": \"{}\", \"leaf\": {}, \"state\": {}, \"qty\": {}}},", self.fetched[2].id, self.fetched[2].name, self.fetched[2].leaf, self.fetched[2].state, self.fetched[2].qty)}</div>
                    }}
                    {if self.fetched.len() > 3 {
                        <div style="font-size: 11px; color: #24292f">{format("  {{\"id\": {}, \"name\": \"{}\", \"leaf\": {}, \"state\": {}, \"qty\": {}}},", self.fetched[3].id, self.fetched[3].name, self.fetched[3].leaf, self.fetched[3].state, self.fetched[3].qty)}</div>
                    }}
                    {if self.fetched.len() > 4 {
                        <div style="font-size: 11px; color: #24292f">{format("  {{\"id\": {}, \"name\": \"{}\", \"leaf\": {}, \"state\": {}, \"qty\": {}}},", self.fetched[4].id, self.fetched[4].name, self.fetched[4].leaf, self.fetched[4].state, self.fetched[4].qty)}</div>
                    }}
                    {if self.fetched.len() > 5 {
                        <div style="font-size: 11px; color: #6e7781">{format("  … {} more nodes in this response", self.fetched.len() - 5)}</div>
                    }}
                    <div style="font-size: 11px; color: #6e7781">"]"</div>
                </div>
            </div>
            </div>
        </div>
    }
}
