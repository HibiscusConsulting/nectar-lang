    fn filter_all(&mut self) {
        if self.capacity == 0 {
            self.status = "not connected — click Connect first";
        } else {
        self.filter_label = "full structure";
        self.scroll_row = 0;
        self.visible = [];
        let mut stack: [i32] = [0];
        while stack.len() > 0 {
            let idx: i32 = stack.pop().unwrap();
            self.visible.push(idx);
            if self.expanded[idx] {
                if self.loaded[idx] {
                    let cc: i32 = self.children_count[idx];
                    let fc: i32 = idx * self.branching + 1;
                    let mut c: i32 = cc - 1;
                    while c >= 0 {
                        stack.push(fc + c);
                        c = c - 1;
                    }
                }
            }
        }
        if self.scroll_row < 0 {
            self.scroll_row = 0;
        }
        let max_scroll: i32 = self.visible.len() - self.viewport_rows;
        if max_scroll < 0 {
            if self.scroll_row > 0 {
                self.scroll_row = 0;
            }
        } else {
            if self.scroll_row > max_scroll {
                self.scroll_row = max_scroll;
            }
        }
        self.window_ids = [];
        self.window_depths = [];
        let total_visible: i32 = self.visible.len();
        let mut r: i32 = self.scroll_row;
        let end: i32 = r + self.viewport_rows;
        while r < end {
            if r >= 0 {
                if r < total_visible {
                    let id: i32 = self.visible[r];
                    let mut dd2: i32 = id;
                    let mut depth2: i32 = 0;
                    while dd2 > 0 {
                        dd2 = (dd2 - 1) / self.branching;
                        depth2 = depth2 + 1;
                    }
                    self.window_ids.push(id);
                    self.window_depths.push(depth2);
                }
            }
            r = r + 1;
        }
            self.status = format("filter cleared: {} rows (tree view)", self.visible.len());
        }
    }
    fn view_iso(&mut self) {
        self.view_name = "iso";
        self.status = "visualization: isometric view";
    }
    fn view_front(&mut self) {
        self.view_name = "front";
        self.status = "visualization: front view";
    }
    fn view_top(&mut self) {
        self.view_name = "top";
        self.status = "visualization: top view";
    }
    fn rot_left(&mut self) {
        self.view_rot = self.view_rot - 1;
        if self.view_rot < 0 { self.view_rot = 7; }
        self.status = format("visualization: yaw {}°", self.view_rot * 45);
    }
    fn rot_right(&mut self) {
        self.view_rot = self.view_rot + 1;
        if self.view_rot > 7 { self.view_rot = 0; }
        self.status = format("visualization: yaw {}°", self.view_rot * 45);
    }
    fn zoom_out(&mut self) {
        self.view_zoom = self.view_zoom - 1;
        if self.view_zoom < 1 { self.view_zoom = 1; }
        self.status = format("visualization: {}x zoom", self.view_zoom);
    }
    fn zoom_in(&mut self) {
        self.view_zoom = self.view_zoom + 1;
        if self.view_zoom > 3 { self.view_zoom = 3; }
        self.status = format("visualization: {}x zoom", self.view_zoom);
    }
