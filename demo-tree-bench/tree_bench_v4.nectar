    fn set_state_0(&mut self) {
        if self.capacity == 0 {
            self.status = "not connected yet";
            return;
        }
        let sid: i32 = self.selected_id;
        self.pending_parent = 0 - 3;
        self.status = format("POST /api/part/update {{\"id\":{},\"state\":0}} … (set Released)", sid);
        self.last_url = format("POST /api/part/update (PN-{})", sid);
        mp::request(format("/api/part/update{}", ""), "POST", format("{{\"id\":{},\"state\":0}}", sid), 0);
    }
