// PLM/ALM tree navigation demo — real Windchill/Codebeamer-style BOM tree.
// 100% Nectar + Honeycomb: canvas render mode, no bespoke JS, no DOM.
//
// Tree is a uniform 6-ary tree computed arithmetically from node index (no per-node
// struct/pointer storage) — child c of node n lives at index n*6 + c + 1. Only stored
// state is `expanded: [bool]`, one entry per node.
//
// Per-row click handlers: this compiler does not support component methods with
// parameters or methods calling other methods (every method compiles to a standalone
// handler), so per-row expand/collapse uses toggle_row_0..toggle_row_19 — one handler
// per visible row slot, each reading self.window_ids[N] for whichever node currently
// occupies that slot. This mirrors the same convention Nectar's own shipped example
// app (alipay-miniprogram-demo.nectar) uses for per-item actions in a fixed-size list
// (remove_item_0, remove_item_1, ...) — not a workaround invented for this app.
//
// Real native mouse-wheel virtualized scrolling is NOT used here: Honeycomb's engine
// has a low-level virtual-range primitive, but there is no working Nectar-level
// construct to bind a multi-million-row array to it in canvas mode today (confirmed:
// the documented `virtual` keyword doesn't parse in canvas mode, and its DOM-mode
// codegen calls an undefined function). So navigation is button-driven windowing,
// which is the honest representation of what's actually built and working.

component TreeBench() {
    let mut branching: i32 = 6;
    let mut max_depth: i32 = 7;
    let mut total_nodes: i32 = 0;

    let mut expanded: [bool] = [];
    let mut visible: [i32] = [];
    let mut scroll_row: i32 = 0;
    let mut viewport_rows: i32 = 20;
    let mut window_ids: [i32] = [];
    let mut window_depths: [i32] = [];

    let mut status: String = "not initialized — click Setup to build the tree";

    fn setup(&mut self) {
        let mut total: i32 = 0;
        let mut level_count: i32 = 1;
        let mut d: i32 = 0;
        while d <= self.max_depth {
            total = total + level_count;
            level_count = level_count * self.branching;
            d = d + 1;
        }
        self.total_nodes = total;

        let mut i: i32 = 0;
        while i < self.total_nodes {
            self.expanded.push(false);
            i = i + 1;
        }
        self.expanded[0] = true;

        self.visible = [];
        let mut stack: [i32] = [0];
        while stack.len() > 0 {
            let idx: i32 = stack.pop().unwrap();
            self.visible.push(idx);
            if self.expanded[idx] {
                let mut dd: i32 = idx;
                let mut depth: i32 = 0;
                while dd > 0 {
                    dd = (dd - 1) / self.branching;
                    depth = depth + 1;
                }
                if depth < self.max_depth {
                    let fc: i32 = idx * self.branching + 1;
                    let mut c: i32 = self.branching - 1;
                    while c >= 0 {
                        let child: i32 = fc + c;
                        if child < self.total_nodes {
                            stack.push(child);
                        }
                        c = c - 1;
                    }
                }
            }
        }
        self.window_ids = [];
        self.window_depths = [];
        let total_visible: i32 = self.visible.len();
        let mut r: i32 = self.scroll_row;
        let end: i32 = r + self.viewport_rows;
        while r < end {
            if r >= 0 {
                if r < total_visible {
                    let id: i32 = self.visible[r];
                    let mut dd2: i32 = id;
                    let mut depth2: i32 = 0;
                    while dd2 > 0 {
                        dd2 = (dd2 - 1) / self.branching;
                        depth2 = depth2 + 1;
                    }
                    self.window_ids.push(id);
                    self.window_depths.push(depth2);
                }
            }
            r = r + 1;
        }
        self.status = format("ready: {} total nodes (branching={}, depth={})", self.total_nodes, self.branching, self.max_depth);
    }
    fn expand_all(&mut self) {
        let mut i: i32 = 0;
        while i < self.total_nodes {
            self.expanded[i] = true;
            i = i + 1;
        }

        self.visible = [];
        let mut stack: [i32] = [0];
        while stack.len() > 0 {
            let idx: i32 = stack.pop().unwrap();
            self.visible.push(idx);
            if self.expanded[idx] {
                let mut dd: i32 = idx;
                let mut depth: i32 = 0;
                while dd > 0 {
                    dd = (dd - 1) / self.branching;
                    depth = depth + 1;
                }
                if depth < self.max_depth {
                    let fc: i32 = idx * self.branching + 1;
                    let mut c: i32 = self.branching - 1;
                    while c >= 0 {
                        let child: i32 = fc + c;
                        if child < self.total_nodes {
                            stack.push(child);
                        }
                        c = c - 1;
                    }
                }
            }
        }
        self.window_ids = [];
        self.window_depths = [];
        let total_visible: i32 = self.visible.len();
        let mut r: i32 = self.scroll_row;
        let end: i32 = r + self.viewport_rows;
        while r < end {
            if r >= 0 {
                if r < total_visible {
                    let id: i32 = self.visible[r];
                    let mut dd2: i32 = id;
                    let mut depth2: i32 = 0;
                    while dd2 > 0 {
                        dd2 = (dd2 - 1) / self.branching;
                        depth2 = depth2 + 1;
                    }
                    self.window_ids.push(id);
                    self.window_depths.push(depth2);
                }
            }
            r = r + 1;
        }
        self.status = format("EXPAND ALL: {} of {} nodes now visible", self.visible.len(), self.total_nodes);
    }
    fn collapse_all(&mut self) {
        let mut i: i32 = 0;
        while i < self.total_nodes {
            self.expanded[i] = false;
            i = i + 1;
        }
        self.expanded[0] = true;
        self.scroll_row = 0;

        self.visible = [];
        let mut stack: [i32] = [0];
        while stack.len() > 0 {
            let idx: i32 = stack.pop().unwrap();
            self.visible.push(idx);
            if self.expanded[idx] {
                let mut dd: i32 = idx;
                let mut depth: i32 = 0;
                while dd > 0 {
                    dd = (dd - 1) / self.branching;
                    depth = depth + 1;
                }
                if depth < self.max_depth {
                    let fc: i32 = idx * self.branching + 1;
                    let mut c: i32 = self.branching - 1;
                    while c >= 0 {
                        let child: i32 = fc + c;
                        if child < self.total_nodes {
                            stack.push(child);
                        }
                        c = c - 1;
                    }
                }
            }
        }
        self.window_ids = [];
        self.window_depths = [];
        let total_visible: i32 = self.visible.len();
        let mut r: i32 = self.scroll_row;
        let end: i32 = r + self.viewport_rows;
        while r < end {
            if r >= 0 {
                if r < total_visible {
                    let id: i32 = self.visible[r];
                    let mut dd2: i32 = id;
                    let mut depth2: i32 = 0;
                    while dd2 > 0 {
                        dd2 = (dd2 - 1) / self.branching;
                        depth2 = depth2 + 1;
                    }
                    self.window_ids.push(id);
                    self.window_depths.push(depth2);
                }
            }
            r = r + 1;
        }
        self.status = format("collapsed all: {} rows visible", self.visible.len());
    }
    fn scroll_to_top(&mut self) {
        self.scroll_row = 0;
        if self.scroll_row < 0 {
            self.scroll_row = 0;
        }
        let max_scroll: i32 = self.visible.len() - self.viewport_rows;
        if max_scroll < 0 {
            if self.scroll_row > 0 {
                self.scroll_row = 0;
            }
        } else {
            if self.scroll_row > max_scroll {
                self.scroll_row = max_scroll;
            }
        }
        self.window_ids = [];
        self.window_depths = [];
        let total_visible: i32 = self.visible.len();
        let mut r: i32 = self.scroll_row;
        let end: i32 = r + self.viewport_rows;
        while r < end {
            if r >= 0 {
                if r < total_visible {
                    let id: i32 = self.visible[r];
                    let mut dd2: i32 = id;
                    let mut depth2: i32 = 0;
                    while dd2 > 0 {
                        dd2 = (dd2 - 1) / self.branching;
                        depth2 = depth2 + 1;
                    }
                    self.window_ids.push(id);
                    self.window_depths.push(depth2);
                }
            }
            r = r + 1;
        }
        self.status = format("top (row 0 of {})", self.visible.len());
    }
    fn scroll_jump_back(&mut self) {
        self.scroll_row = self.scroll_row - 1000;
        if self.scroll_row < 0 {
            self.scroll_row = 0;
        }
        let max_scroll: i32 = self.visible.len() - self.viewport_rows;
        if max_scroll < 0 {
