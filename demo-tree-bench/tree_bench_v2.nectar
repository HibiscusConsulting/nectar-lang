                        <div style="width: 26px; font-size: 12px; color: #f0c869">{if self.window_depths[0] < self.max_depth { {if self.expanded[self.window_ids[0]] { "▾" } else { "▸" }} } else { "·" }}</div>
                        <div style="width: 190px; font-size: 12px; color: #6e828f">{if self.window_depths[0] == 0 { "Top Assembly" } else { {if self.window_depths[0] == 1 { "Major Assembly" } else { {if self.window_depths[0] == 2 { "Sub-Assembly" } else { {if self.window_depths[0] == 3 { "Component" } else { {if self.window_depths[0] == 4 { "Sub-Component" } else { {if self.window_depths[0] == 5 { "Detail Part" } else { {if self.window_depths[0] == 6 { "Fastener Group" } else { {if self.window_depths[0] == 7 { "Fastener" } else { "Fastener" }} }} }} }} }} }} }} }}</div>
