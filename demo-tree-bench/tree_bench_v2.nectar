                    }
                    self.window_ids.push(id);
                    self.window_depths.push(depth2);
                }
            }
            r = r + 1;
        }
        self.status = format("row {} of {}", self.scroll_row, self.visible.len());
    }
    fn scroll_page_up(&mut self) {
        self.scroll_row = self.scroll_row - self.viewport_rows;
        if self.scroll_row < 0 {
            self.scroll_row = 0;
        }
        let max_scroll: i32 = self.visible.len() - self.viewport_rows;
