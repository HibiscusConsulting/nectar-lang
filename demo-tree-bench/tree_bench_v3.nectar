    render {
        <div style="direction: vertical; width: fill; height: fill; background-color: #0b0e14; padding: 20; gap: 12">
            <div style="direction: vertical; gap: 3">
                <div style="font-size: 20px; font-weight: 700; color: #f0c869">"PLM/ALM Tree Navigator"</div>
                <div style="font-size: 12px; color: #545d68">"Synthetic BOM tree · demonstrates canvas-mode expand/collapse + windowed navigation at scale · not a live Windchill/Codebeamer connection"</div>
            </div>
            <div style="font-size: 13px; color: #8b949e">{self.status}</div>

            <div style="direction: horizontal; gap: 6; height: 34px">
                <div style="height: 32px; padding: 0 12; background-color: #1c2128; border: 1px solid #2a323c; border-radius: 6; color: #c9d1d9; font-size: 12px; align: center; justify: center; cursor: pointer" on:click={self.setup}>"Setup"</div>
                <div style="height: 32px; padding: 0 12; background-color: #1c2128; border: 1px solid #2a323c; border-radius: 6; color: #c9d1d9; font-size: 12px; align: center; justify: center; cursor: pointer" on:click={self.expand_all}>"Expand all (stress)"</div>
                <div style="height: 32px; padding: 0 12; background-color: #1c2128; border: 1px solid #2a323c; border-radius: 6; color: #c9d1d9; font-size: 12px; align: center; justify: center; cursor: pointer" on:click={self.collapse_all}>"Collapse all"</div>
                <div style="height: 32px; padding: 0 12; background-color: #1c2128; border: 1px solid #2a323c; border-radius: 6; color: #c9d1d9; font-size: 12px; align: center; justify: center; cursor: pointer" on:click={self.scroll_to_top}>"Top"</div>
                <div style="height: 32px; padding: 0 12; background-color: #1c2128; border: 1px solid #2a323c; border-radius: 6; color: #c9d1d9; font-size: 12px; align: center; justify: center; cursor: pointer" on:click={self.scroll_page_up}>"Page up"</div>
                <div style="height: 32px; padding: 0 12; background-color: #1c2128; border: 1px solid #2a323c; border-radius: 6; color: #c9d1d9; font-size: 12px; align: center; justify: center; cursor: pointer" on:click={self.scroll_page_down}>"Page down"</div>
                <div style="height: 32px; padding: 0 12; background-color: #1c2128; border: 1px solid #2a323c; border-radius: 6; color: #c9d1d9; font-size: 12px; align: center; justify: center; cursor: pointer" on:click={self.scroll_to_middle}>"Middle"</div>
                <div style="height: 32px; padding: 0 12; background-color: #1c2128; border: 1px solid #2a323c; border-radius: 6; color: #c9d1d9; font-size: 12px; align: center; justify: center; cursor: pointer" on:click={self.scroll_to_bottom}>"Bottom"</div>
            </div>

            <div style="direction: horizontal; gap: 4; height: 28px; align: center">
                {if self.window_depths.len() > 0 {
                    {if self.window_depths[0] >= 0 {
                        <div style="font-size: 12px; color: #8b949e; padding: 3 8; background-color: #161b22; border-radius: 4; cursor: pointer" on:click={self.breadcrumb_jump_0}>"Top Assembly"</div>
                    }}
                }}
                {if self.window_depths.len() > 0 {
                    {if self.window_depths[0] >= 1 { <div style="color: #3a4552; font-size: 12px; padding: 0 2">"›"</div> }}
                    {if self.window_depths[0] >= 1 {
                        <div style="font-size: 12px; color: #8b949e; padding: 3 8; background-color: #161b22; border-radius: 4; cursor: pointer" on:click={self.breadcrumb_jump_1}>"Major Assembly"</div>
                    }}
